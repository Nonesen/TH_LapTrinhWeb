<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <!-- Loại bỏ thư mục images khỏi Content và Watch để tránh File Watcher và Hot Reload tự động reset máy chủ khi upload ảnh -->
    <Content Remove="wwwroot\images\**" />
    <Watch Include="wwwroot/images/**/*" Watch="false" />
  </ItemGroup>

</Project>
