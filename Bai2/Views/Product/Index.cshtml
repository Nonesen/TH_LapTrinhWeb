@model IEnumerable<Bai2.Models.Product>

@{
    ViewData["Title"] = "Trang Chủ";
}

<div class="container">
    <div class="row g-4">
        <!-- Cột chính: Danh sách sản phẩm -->
        <div class="col-lg-9 col-md-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h3 class="section-title mb-1">Thiết Bị Công Nghệ</h3>
                    <p class="text-muted small mb-0">Hệ thống quản lý thông tin và phân phối sản phẩm chính hãng</p>
                </div>
                <a asp-action="Add" class="btn btn-modern-primary d-flex align-items-center gap-2">
                    <i class="bi bi-plus-lg"></i> Thêm Sản Phẩm
                </a>
            </div>

            <!-- Lưới hiển thị danh sách sản phẩm -->
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                @foreach (var product in Model)
                {
                    <div class="col">
                        <div class="card h-100 border-0 product-grid-card">
                            <!-- Phần ảnh / biểu tượng sản phẩm -->
                            <div class="position-relative overflow-hidden bg-light d-flex align-items-center justify-content-center" style="height: 180px;">
                                @if (!string.IsNullOrEmpty(product.ImageUrl))
                                {
                                    <img src="@product.ImageUrl" class="w-100 h-100" alt="@product.Name" style="object-fit: cover;">
                                }
                                else
                                {
                                    <!-- Fallback icon thông minh theo CategoryId -->
                                    <div class="text-center">
                                        @if (product.CategoryId == 1)
                                        {
                                            <i class="bi bi-laptop text-primary" style="font-size: 4rem;"></i>
                                            <span class="d-block small text-muted mt-1">Laptop Device</span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-phone text-primary" style="font-size: 4rem;"></i>
                                            <span class="d-block small text-muted mt-1">Phone Device</span>
                                        }
                                    </div>
                                }
                                <div class="position-absolute top-0 end-0 m-3">
                                    <span class="badge bg-dark text-white px-2.5 py-1.5 rounded-pill shadow-sm" style="font-size: 0.75rem;">
                                        @(product.CategoryId == 1 ? "Laptop" : "Điện thoại")
                                    </span>
                                </div>
                            </div>

                            <!-- Nội dung sản phẩm -->
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-2 text-truncate" title="@product.Name">@product.Name</h5>
                                <p class="text-muted small mb-4 text-truncate-2" style="height: 38px; line-height: 1.4; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                                    @product.Description
                                </p>
                                
                                <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
                                    <span class="product-price-badge">$@product.Price.ToString("#,##0")</span>
                                    
                                    <!-- Nhóm các hành động CRUD -->
                                    <div class="d-flex gap-2">
                                        <a asp-action="Display" asp-route-id="@product.Id" class="btn btn-outline-primary btn-sm rounded-3 px-3">Chi Tiết</a>
                                        
                                        <div class="dropdown">
                                            <button class="btn btn-light btn-sm rounded-3" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                                <i class="bi bi-three-dots-vertical"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3">
                                                <li>
                                                    <a class="dropdown-item text-warning" asp-action="Update" asp-route-id="@product.Id">
                                                        <i class="bi bi-pencil-square me-2"></i>Chỉnh Sửa
                                                    </a>
                                                </li>
                                                <li><hr class="dropdown-divider"></li>
                                                <li>
                                                    <a class="dropdown-item text-danger" asp-action="Delete" asp-route-id="@product.Id">
                                                        <i class="bi bi-trash3 me-2"></i>Xóa Bỏ
                                                    </a>
                                                </li>
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Cột phụ bên phải: Sidebar -->
        <div class="col-lg-3 col-md-4">
            <!-- Box 1: Danh Mục -->
            <div class="tech-sidebar-box mb-4">
                <h5 class="fw-bold mb-3 border-bottom pb-2 text-primary">
                    <i class="bi bi-tags-fill me-2"></i>Phân Loại
                </h5>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between align-items-center bg-transparent px-0 py-2">
                        <span class="small fw-semibold text-secondary"><i class="bi bi-chevron-right me-1"></i>Laptops</span>
                        <span class="badge bg-primary rounded-pill">Active</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center bg-transparent px-0 py-2">
                        <span class="small fw-semibold text-secondary"><i class="bi bi-chevron-right me-1"></i>Phones (Điện thoại)</span>
                        <span class="badge bg-primary rounded-pill">Active</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>
