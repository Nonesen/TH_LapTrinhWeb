@model Bai2.Models.Product

@{
    ViewData["Title"] = "Product Details";
}

<h2>Product Details</h2>

<div>
    <h4>Name: @Model.Name</h4>
    <h4>Price: @Model.Price.ToString("C")</h4>
    <h4>Description: @Model.Description</h4>
    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <div class="mt-3">
            <h5>Product Image:</h5>
            <img src="@Model.ImageUrl" width="200" />
        </div>
    }
    @if (Model.ImageUrls != null && Model.ImageUrls.Count > 0)
    {
        <div class="mt-3">
            <h5>Other Images:</h5>
            @foreach (var url in Model.ImageUrls)
            {
                <img src="@url" width="100" class="me-2" />
            }
        </div>
    }
</div>

<hr />
<div class="mt-3">
    <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a> |
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
