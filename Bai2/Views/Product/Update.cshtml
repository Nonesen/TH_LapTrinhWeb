@model Bai2.Models.Product

@{
    ViewData["Title"] = "Chỉnh Sửa Thiết Bị";
}

<div class="container mt-4" style="max-width: 650px;">
    <!-- Breadcrumb điều hướng -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-action="Index" class="text-primary text-decoration-none fw-semibold">Trang chủ</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="Display" asp-route-id="@Model.Id" class="text-primary text-decoration-none">@Model.Name</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Cấu hình lại</li>
        </ol>
    </nav>

    <!-- Thẻ Form cập nhật -->
    <div class="modern-form-card">
        <div class="border-bottom pb-3 mb-4 text-center">
            <h3 class="fw-bold text-primary mb-1">
                <i class="bi bi-pencil-square me-2"></i>Cấu Hình Thiết Bị
            </h3>
            <p class="text-muted small mb-0">Cập nhật thông tin chi tiết cho thiết bị phần cứng của bạn</p>
        </div>

        <form asp-action="Update" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="All" class="text-danger small mb-3"></div>

            <!-- Tên sản phẩm -->
            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label fw-semibold text-secondary mb-1">Tên Thiết Bị</label>
                <input asp-for="Name" class="form-control form-control-modern" placeholder="Nhập tên thiết bị..." />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="row">
                <!-- Giá bán -->
                <div class="col-md-6 form-group mb-3">
                    <label asp-for="Price" class="control-label fw-semibold text-secondary mb-1">Giá Bán (USD)</label>
                    <input asp-for="Price" type="number" class="form-control form-control-modern" />
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>

                <!-- Danh mục -->
                <div class="col-md-6 form-group mb-3">
                    <label asp-for="CategoryId" class="control-label fw-semibold text-secondary mb-1">Loại Thiết Bị</label>
                    <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select form-control-modern"></select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>
            </div>

            <!-- Mô tả chi tiết -->
            <div class="form-group mb-3">
                <label asp-for="Description" class="control-label fw-semibold text-secondary mb-1">Thông Số Kỹ Thuật / Mô Tả</label>
                <textarea asp-for="Description" rows="4" class="form-control form-control-modern" placeholder="Nhập mô tả chi tiết..."></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <!-- Ảnh đại diện cũ & mới -->
            <div class="form-group mb-3">
                <label asp-for="ImageUrl" class="control-label fw-semibold text-secondary mb-1">Cập Nhật Ảnh Thiết Bị</label>
                
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="mb-2 p-2 border rounded-3 bg-light text-center" style="max-width: 150px;">
                        <span class="d-block small text-muted mb-1">Ảnh hiện có:</span>
                        <img src="@Model.ImageUrl" class="img-thumbnail rounded-3" style="max-height: 100px; object-fit: contain;" />
                    </div>
                }

                <div class="input-group">
                    <span class="input-group-text bg-light border-2"><i class="bi bi-image"></i></span>
                    <input type="file" name="ImageUrl" class="form-control form-control-modern" accept="image/*" />
                </div>
                <small class="text-muted">Chọn tệp tin ảnh mới để thay đổi ảnh đại diện chính của thiết bị.</small>
            </div>

            <!-- Các ảnh khác liên quan -->
            <div class="form-group mb-4">
                <label asp-for="ImageUrls" class="control-label fw-semibold text-secondary mb-1">Cập Nhật Thư Viện Ảnh Phụ</label>

                @if (Model.ImageUrls != null && Model.ImageUrls.Count > 0)
                {
                    <div class="mb-2 p-2 border rounded-3 bg-light">
                        <span class="d-block small text-muted mb-1">Các ảnh phụ hiện có:</span>
                        <div class="d-flex gap-2 flex-wrap">
                            @foreach (var url in Model.ImageUrls)
                            {
                                <img src="@url" class="img-thumbnail rounded-2" style="width: 50px; height: 50px; object-fit: cover;" />
                            }
                        </div>
                    </div>
                }

                <div class="input-group">
                    <span class="input-group-text bg-light border-2"><i class="bi bi-images"></i></span>
                    <input type="file" name="ImageUrls" class="form-control form-control-modern" accept="image/*" multiple />
                </div>
                <small class="text-muted">Tải lên các tệp tin mới để cập nhật lại toàn bộ thư viện ảnh phụ.</small>
            </div>

            <!-- Nút điều khiển -->
            <div class="d-flex gap-3 justify-content-center pt-3 border-top">
                <button type="submit" class="btn btn-modern-primary"><i class="bi bi-save me-2"></i>Cập Nhật</button>
                <a asp-action="Index" class="btn btn-modern-secondary"><i class="bi bi-x-lg me-2"></i>Hủy bỏ</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
