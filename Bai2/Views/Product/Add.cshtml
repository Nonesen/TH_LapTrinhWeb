@model Bai2.Models.Product
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Thêm Thiết Bị";
}

<div class="container mt-4" style="max-width: 650px;">
    <!-- Breadcrumb điều hướng -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-action="Index" class="text-primary text-decoration-none fw-semibold">Trang chủ</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Thêm thiết bị</li>
        </ol>
    </nav>

    <!-- Thẻ Form thêm mới -->
    <div class="modern-form-card">
        <div class="border-bottom pb-3 mb-4 text-center">
            <h3 class="fw-bold text-primary mb-1">
                <i class="bi bi-plus-square-fill me-2"></i>Thêm Mới Thiết Bị
            </h3>
            <p class="text-muted small mb-0">Đăng ký thiết bị phần cứng mới vào hệ thống WebsiteBanHang</p>
        </div>

        <form asp-action="Add" enctype="multipart/form-data" class="needs-validation">
            <div asp-validation-summary="All" class="text-danger small mb-3"></div>

            <!-- Tên sản phẩm -->
            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label fw-semibold text-secondary mb-1">Tên Thiết Bị</label>
                <input asp-for="Name" class="form-control form-control-modern" placeholder="Nhập tên thiết bị (ví dụ: Dell XPS 15, HP Pavilion)..." />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="row">
                <!-- Giá bán -->
                <div class="col-md-6 form-group mb-3">
                    <label asp-for="Price" class="control-label fw-semibold text-secondary mb-1">Giá Bán (USD)</label>
                    <input asp-for="Price" type="number" class="form-control form-control-modern" placeholder="Ví dụ: 1000..." />
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>

                <!-- Danh mục -->
                <div class="col-md-6 form-group mb-3">
                    <label asp-for="CategoryId" class="control-label fw-semibold text-secondary mb-1">Loại Thiết Bị</label>
                    <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select form-control-modern">
                        <option value="">-- Chọn danh mục --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>
            </div>

            <!-- Mô tả chi tiết -->
            <div class="form-group mb-3">
                <label asp-for="Description" class="control-label fw-semibold text-secondary mb-1">Thông Số Kỹ Thuật / Mô Tả</label>
                <textarea asp-for="Description" rows="4" class="form-control form-control-modern" placeholder="Nhập cấu hình thiết bị, thông số RAM, CPU, ổ cứng..."></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <!-- Ảnh đại diện -->
            <div class="form-group mb-3">
                <label asp-for="ImageUrl" class="control-label fw-semibold text-secondary mb-1">Hình Ảnh Thiết Bị</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-2"><i class="bi bi-image"></i></span>
                    <input type="file" name="ImageUrl" class="form-control form-control-modern" accept="image/*" />
                </div>
                <small class="text-muted">Tải lên hình ảnh rõ ràng của thiết bị phần cứng.</small>
            </div>

            <!-- Các ảnh khác liên quan -->
            <div class="form-group mb-4">
                <label asp-for="ImageUrls" class="control-label fw-semibold text-secondary mb-1">Thư Viện Ảnh Mô Tả (Chọn nhiều ảnh)</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-2"><i class="bi bi-images"></i></span>
                    <input type="file" name="ImageUrls" class="form-control form-control-modern" accept="image/*" multiple />
                </div>
                <small class="text-muted">Chọn các ảnh góc chụp khác của sản phẩm nếu có.</small>
            </div>

            <!-- Nút điều khiển -->
            <div class="d-flex gap-3 justify-content-center pt-3 border-top">
                <button type="submit" class="btn btn-modern-primary"><i class="bi bi-check-lg me-2"></i>Thêm Mới</button>
                <a asp-action="Index" class="btn btn-modern-secondary"><i class="bi bi-x-lg me-2"></i>Hủy bỏ</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
